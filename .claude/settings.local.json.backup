      "Bash(analyze_losing_trades.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Detailed analysis of losing trades from blowout strategy.\"\"\"\n\nimport json\nfrom pathlib import Path\nfrom src.backtesting.engine import BacktestEngine, BacktestConfig\nfrom src.backtesting.adapters.nba_adapter import NBADataFeed, BlowoutAdapter\n\n# The 4 losing trades\nlosing_games = [\n    \\(\"CLE_vs_LAC_20260204_214639.json\", -0.30\\),\n    \\(\"IND_vs_TOR_20260208_143224.json\", -0.30\\),\n    \\(\"MEM_vs_GSW_20260209_212836.json\", -4.63\\),\n    \\(\"HOU_vs_NYK_20260221_201054.json\", -4.72\\),\n]\n\nconfig = BacktestConfig\\(\n    initial_bankroll=100.0,\n    fill_probability=1.0,\n    slippage=0.03,\n\\)\n\nfor game_file, expected_loss in losing_games:\n    recording = f\"data/recordings/{game_file}\"\n    print\\(\"=\" * 80\\)\n    print\\(f\"ANALYZING: {game_file}\"\\)\n    print\\(f\"Expected loss: ${expected_loss:.2f}\"\\)\n    print\\(\"=\" * 80\\)\n    \n    # Load the game data\n    with open\\(recording\\) as f:\n        game_data = json.load\\(f\\)\n    \n    # Print game metadata\n    print\\(f\"\\\\nGame ID: {game_data.get\\('game_id'\\)}\"\\)\n    print\\(f\"Date: {game_data.get\\('date'\\)}\"\\)\n    print\\(f\"Home: {game_data.get\\('home_team'\\)} vs Away: {game_data.get\\('away_team'\\)}\"\\)\n    \n    # Find final score if available\n    snapshots = game_data.get\\('snapshots', []\\)\n    if snapshots:\n        final = snapshots[-1]\n        print\\(f\"Final Score: Away {final.get\\('away_score'\\)} - Home {final.get\\('home_score'\\)}\"\\)\n        print\\(f\"Total snapshots: {len\\(snapshots\\)}\"\\)\n    \n    # Run backtest with verbose to see trade details\n    print\\(\"\\\\nRunning backtest...\"\\)\n    feed = NBADataFeed\\(recording\\)\n    adapter = BlowoutAdapter\\(\\)\n    engine = BacktestEngine\\(config\\)\n    result = engine.run\\(feed, adapter, verbose=True\\)\n    \n    print\\(f\"\\\\n{result.report\\(\\)}\"\\)\n    \n    # Analyze the fills\n    if result.fills:\n        for i, fill in enumerate\\(result.fills, 1\\):\n            print\\(f\"\\\\nFill #{i}:\"\\)\n            print\\(f\"  Ticker: {fill.ticker}\"\\)\n            print\\(f\"  Side: {fill.side}\"\\)\n            print\\(f\"  Price: ${fill.price:.4f}\"\\)\n            print\\(f\"  Size: {fill.size}\"\\)\n            print\\(f\"  Fee: ${fill.fee:.4f}\"\\)\n            print\\(f\"  Timestamp: {fill.timestamp}\"\\)\n            \n            # Get settlement\n            settlement = result.settlements.get\\(fill.ticker\\)\n            print\\(f\"  Settlement: {settlement}\"\\)\n            \n            # Calculate P&L\n            if fill.side == \"BID\":  # bought YES\n                pnl = \\(settlement - fill.price\\) * fill.size if settlement is not None else -fill.price * fill.size\n            else:  # sold YES \\(bought NO\\)\n                pnl = \\(fill.price - settlement\\) * fill.size if settlement is not None else fill.price * fill.size\n            \n            print\\(f\"  P&L \\(before fees\\): ${pnl:.2f}\"\\)\n            print\\(f\"  P&L \\(after fees\\): ${pnl - fill.fee:.2f}\"\\)\n    \n    print\\(\"\\\\n\" + \"=\" * 80 + \"\\\\n\"\\)\nEOF)",
      "Bash(__NEW_LINE_7c646a9c8fd6e5bf__ python3 analyze_losing_trades.py)",
      "Bash(analyze_big_losers.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Deep dive into the two big losing trades.\"\"\"\n\nimport json\nfrom datetime import datetime\n\ndef analyze_game\\(recording_path, team_we_bet\\):\n    with open\\(recording_path\\) as f:\n        data = json.load\\(f\\)\n    \n    snapshots = data.get\\('snapshots', []\\)\n    \n    print\\(f\"\\\\nGame: {data.get\\('away_team'\\)} @ {data.get\\('home_team'\\)}\"\\)\n    print\\(f\"Date: {data.get\\('date'\\)}\"\\)\n    print\\(f\"Team we bet on: {team_we_bet}\"\\)\n    print\\(f\"Total snapshots: {len\\(snapshots\\)}\\\\n\"\\)\n    \n    # Find the entry point \\(look for when market is around 92-94 cents\\)\n    entry_snapshot = None\n    entry_idx = None\n    \n    for idx, snap in enumerate\\(snapshots\\):\n        markets = snap.get\\('markets', {}\\)\n        for ticker, market in markets.items\\(\\):\n            if team_we_bet in ticker:\n                mid_price = \\(market.get\\('yes_bid', 0\\) + market.get\\('yes_ask', 100\\)\\) / 200.0\n                # Look for entry around 92-94 cents\n                if 0.90 <= mid_price <= 0.96:\n                    entry_snapshot = snap\n                    entry_idx = idx\n                    break\n        if entry_snapshot:\n            break\n    \n    if not entry_snapshot:\n        print\\(\"Could not find entry point!\"\\)\n        return\n    \n    # Print entry context\n    print\\(f\"ENTRY POINT \\(snapshot #{entry_idx}\\):\"\\)\n    print\\(f\"  Time: {entry_snapshot.get\\('game_clock'\\)}\"\\)\n    print\\(f\"  Quarter: {entry_snapshot.get\\('quarter'\\)}\"\\)\n    print\\(f\"  Score: {data.get\\('away_team'\\)} {entry_snapshot.get\\('away_score'\\)} - {data.get\\('home_team'\\)} {entry_snapshot.get\\('home_score'\\)}\"\\)\n    \n    markets = entry_snapshot.get\\('markets', {}\\)\n    for ticker, market in markets.items\\(\\):\n        if team_we_bet in ticker:\n            bid = market.get\\('yes_bid', 0\\) / 100.0\n            ask = market.get\\('yes_ask', 100\\) / 100.0\n            print\\(f\"  Market price: Bid ${bid:.2f}, Ask ${ask:.2f}, Mid ${\\(bid+ask\\)/2:.2f}\"\\)\n    \n    # Calculate score differential at entry\n    away_score = entry_snapshot.get\\('away_score', 0\\)\n    home_score = entry_snapshot.get\\('home_score', 0\\)\n    if team_we_bet == data.get\\('home_team'\\):\n        score_diff = home_score - away_score\n    else:\n        score_diff = away_score - home_score\n    \n    print\\(f\"  {team_we_bet} leading by: {score_diff} points\"\\)\n    \n    # Show progression after entry \\(every 50 snapshots\\)\n    print\\(f\"\\\\nGAME PROGRESSION AFTER ENTRY:\"\\)\n    print\\(f\"  {'Snapshot':<10} {'Quarter':<8} {'Clock':<10} {'Away Score':<12} {'Home Score':<12} {'Lead':<8} {'Market Price':<12}\"\\)\n    print\\(f\"  {'-'*90}\"\\)\n    \n    for i in range\\(entry_idx, len\\(snapshots\\), max\\(1, \\(len\\(snapshots\\) - entry_idx\\) // 10\\)\\):\n        snap = snapshots[i]\n        away_sc = snap.get\\('away_score', 0\\)\n        home_sc = snap.get\\('home_score', 0\\)\n        \n        if team_we_bet == data.get\\('home_team'\\):\n            lead = home_sc - away_sc\n        else:\n            lead = away_sc - home_sc\n        \n        # Get market price\n        markets = snap.get\\('markets', {}\\)\n        market_price = \"N/A\"\n        for ticker, market in markets.items\\(\\):\n            if team_we_bet in ticker:\n                bid = market.get\\('yes_bid', 0\\) / 100.0\n                ask = market.get\\('yes_ask', 100\\) / 100.0\n                market_price = f\"${\\(bid+ask\\)/2:.2f}\"\n                break\n        \n        print\\(f\"  {i:<10} {snap.get\\('quarter', 'N/A'\\):<8} {snap.get\\('game_clock', 'N/A'\\):<10} \"\n              f\"{away_sc:<12} {home_sc:<12} {'+' if lead > 0 else ''}{lead:<8} {market_price:<12}\"\\)\n    \n    # Final snapshot\n    final = snapshots[-1]\n    print\\(f\"\\\\nFINAL RESULT:\"\\)\n    print\\(f\"  Score: {data.get\\('away_team'\\)} {final.get\\('away_score'\\)} - {data.get\\('home_team'\\)} {final.get\\('home_score'\\)}\"\\)\n    \n    away_final = final.get\\('away_score', 0\\)\n    home_final = final.get\\('home_score', 0\\)\n    \n    if team_we_bet == data.get\\('home_team'\\):\n        if home_final > away_final:\n            print\\(f\"  Result: {team_we_bet} WON\"\\)\n        else:\n            print\\(f\"  Result: {team_we_bet} LOST by {away_final - home_final} points\"\\)\n    else:\n        if away_final > home_final:\n            print\\(f\"  Result: {team_we_bet} WON\"\\)\n        else:\n            print\\(f\"  Result: {team_we_bet} LOST by {home_final - away_final} points\"\\)\n    \n    # Calculate how much lead was lost\n    final_lead = \\(away_final - home_final\\) if team_we_bet == data.get\\('away_team'\\) else \\(home_final - away_final\\)\n    lead_lost = score_diff - final_lead\n    print\\(f\"  Lead at entry: +{score_diff}\"\\)\n    print\\(f\"  Final margin: {'+' if final_lead > 0 else ''}{final_lead}\"\\)\n    print\\(f\"  Total swing: {lead_lost} points\"\\)\n\n# Analyze the two big losers\nprint\\(\"=\" * 100\\)\nprint\\(\"DEEP DIVE: BIG LOSING TRADES\"\\)\nprint\\(\"=\" * 100\\)\n\nprint\\(\"\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #1: Memphis Grizzlies @ Golden State Warriors\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/MEM_vs_GSW_20260209_212836.json\", \"MEM\"\\)\n\nprint\\(\"\\\\n\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #2: Houston Rockets @ New York Knicks\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/HOU_vs_NYK_20260221_201054.json\", \"HOU\"\\)\n\nEOF)",
      "Bash(__NEW_LINE_c712a43ce6ce51f8__ python3 analyze_big_losers.py)",
      "Bash(analyze_big_losers.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Deep dive into the two big losing trades.\"\"\"\n\nimport json\n\ndef analyze_game\\(recording_path, team_abbrev\\):\n    with open\\(recording_path\\) as f:\n        data = json.load\\(f\\)\n    \n    metadata = data.get\\('metadata', {}\\)\n    frames = data.get\\('frames', []\\)\n    \n    print\\(f\"\\\\nGame: {metadata.get\\('away_team'\\)} @ {metadata.get\\('home_team'\\)}\"\\)\n    print\\(f\"Date: {metadata.get\\('date'\\)}\"\\)\n    print\\(f\"Final Score: {metadata.get\\('away_team'\\)} {metadata.get\\('final_away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {metadata.get\\('final_home_score'\\)}\"\\)\n    print\\(f\"Team we bet on: {team_abbrev}\"\\)\n    print\\(f\"Total frames: {len\\(frames\\)}\\\\n\"\\)\n    \n    # Determine if we bet on home or away\n    is_home = \\(team_abbrev == metadata.get\\('home_team'\\)\\)\n    \n    # Find the entry point \\(look for when market is around 92-94 cents\\)\n    entry_frame = None\n    entry_idx = None\n    \n    for idx, frame in enumerate\\(frames\\):\n        if is_home:\n            bid = frame.get\\('home_bid', 0\\) / 100.0\n            ask = frame.get\\('home_ask', 100\\) / 100.0\n        else:\n            bid = frame.get\\('away_bid', 0\\) / 100.0\n            ask = frame.get\\('away_ask', 100\\) / 100.0\n        \n        mid_price = \\(bid + ask\\) / 2.0\n        \n        # Look for entry around 92-94 cents\n        if 0.90 <= mid_price <= 0.96:\n            entry_frame = frame\n            entry_idx = idx\n            break\n    \n    if not entry_frame:\n        print\\(\"Could not find entry point!\"\\)\n        return\n    \n    # Print entry context\n    print\\(f\"ENTRY POINT \\(frame #{entry_idx} of {len\\(frames\\)}\\):\"\\)\n    print\\(f\"  Period: {entry_frame.get\\('period'\\)}\"\\)\n    print\\(f\"  Time remaining: {entry_frame.get\\('time_remaining'\\)}\"\\)\n    print\\(f\"  Score: {metadata.get\\('away_team'\\)} {entry_frame.get\\('away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {entry_frame.get\\('home_score'\\)}\"\\)\n    \n    if is_home:\n        bid = entry_frame.get\\('home_bid', 0\\) / 100.0\n        ask = entry_frame.get\\('home_ask', 100\\) / 100.0\n    else:\n        bid = entry_frame.get\\('away_bid', 0\\) / 100.0\n        ask = entry_frame.get\\('away_ask', 100\\) / 100.0\n    \n    print\\(f\"  Market price: Bid ${bid:.2f}, Ask ${ask:.2f}, Mid ${\\(bid+ask\\)/2:.2f}\"\\)\n    \n    # Calculate score differential at entry\n    away_score = entry_frame.get\\('away_score', 0\\)\n    home_score = entry_frame.get\\('home_score', 0\\)\n    if is_home:\n        score_diff = home_score - away_score\n    else:\n        score_diff = away_score - home_score\n    \n    print\\(f\"  {team_abbrev} {'leading' if score_diff > 0 else 'trailing'} by: {abs\\(score_diff\\)} points\"\\)\n    print\\(f\"  Win probability \\(implied\\): {\\(bid+ask\\)/2*100:.1f}%\"\\)\n    \n    # Show progression after entry\n    print\\(f\"\\\\nGAME PROGRESSION AFTER ENTRY:\"\\)\n    print\\(f\"  {'Frame':<8} {'Period':<8} {'Time Left':<12} {'Away':<6} {'Home':<6} {team_abbrev + ' Lead':<12} {'Market :<10} {'Win %':<8}\"\\)\n    print\\(f\"  {'-'*80}\"\\)\n    \n    step = max\\(1, \\(len\\(frames\\) - entry_idx\\) // 15\\)\n    for i in range\\(entry_idx, len\\(frames\\), step\\):\n        frame = frames[i]\n        away_sc = frame.get\\('away_score', 0\\)\n        home_sc = frame.get\\('home_score', 0\\)\n        \n        if is_home:\n            lead = home_sc - away_sc\n            bid = frame.get\\('home_bid', 0\\) / 100.0\n            ask = frame.get\\('home_ask', 100\\) / 100.0\n        else:\n            lead = away_sc - home_sc\n            bid = frame.get\\('away_bid', 0\\) / 100.0\n            ask = frame.get\\('away_ask', 100\\) / 100.0\n        \n        mid = \\(bid + ask\\) / 2.0\n        \n        print\\(f\"  {i:<8} {frame.get\\('period', 'N/A'\\):<8} {frame.get\\('time_remaining', 'N/A'\\):<12} \"\n              f\"{away_sc:<6} {home_sc:<6} {'+' if lead > 0 else ''}{lead:<12} ${mid:<9.2f} {mid*100:<7.1f}%\"\\)\n    \n    # Final frame\n    final = frames[-1]\n    print\\(f\"\\\\nFINAL RESULT:\"\\)\n    print\\(f\"  Score: {metadata.get\\('away_team'\\)} {metadata.get\\('final_away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {metadata.get\\('final_home_score'\\)}\"\\)\n    \n    away_final = metadata.get\\('final_away_score', 0\\)\n    home_final = metadata.get\\('final_home_score', 0\\)\n    \n    if is_home:\n        won = home_final > away_final\n        final_margin = home_final - away_final\n    else:\n        won = away_final > home_final\n        final_margin = away_final - home_final\n    \n    print\\(f\"  Result: {team_abbrev} {'WON' if won else 'LOST'}\"\\)\n    print\\(f\"  Final margin: {'+' if final_margin > 0 else ''}{final_margin} points\"\\)\n    \n    # Calculate the collapse\n    print\\(f\"\\\\nTHE COLLAPSE:\"\\)\n    print\\(f\"  Lead at entry: {'+' if score_diff > 0 else ''}{score_diff}\"\\)\n    print\\(f\"  Final margin: {'+' if final_margin > 0 else ''}{final_margin}\"\\)\n    print\\(f\"  Total swing: {score_diff - final_margin} points\"\\)\n    print\\(f\"  Win probability at entry: {\\(bid+ask\\)/2*100:.1f}%\"\\)\n    print\\(f\"  Actual result: {'Win' if won else 'Loss'}\"\\)\n\n# Analyze the two big losers\nprint\\(\"=\" * 100\\)\nprint\\(\"DEEP DIVE: BIG LOSING TRADES\"\\)\nprint\\(\"=\" * 100\\)\n\nprint\\(\"\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #1: Memphis Grizzlies @ Golden State Warriors \\(-$4.63\\)\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/MEM_vs_GSW_20260209_212836.json\", \"MEM\"\\)\n\nprint\\(\"\\\\n\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #2: Houston Rockets @ New York Knicks \\(-$4.72\\)\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/HOU_vs_NYK_20260221_201054.json\", \"HOU\"\\)\n\nEOF)",
      "Bash(__NEW_LINE_d5a92173a5214c37__ python3 analyze_big_losers.py)",
      "Bash(analyze_big_losers_fixed.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Deep dive into the two big losing trades - FIXED.\"\"\"\n\nimport json\n\ndef analyze_game\\(recording_path, team_abbrev\\):\n    with open\\(recording_path\\) as f:\n        data = json.load\\(f\\)\n    \n    metadata = data.get\\('metadata', {}\\)\n    frames = data.get\\('frames', []\\)\n    \n    print\\(f\"\\\\nGame: {metadata.get\\('away_team'\\)} @ {metadata.get\\('home_team'\\)}\"\\)\n    print\\(f\"Date: {metadata.get\\('date'\\)}\"\\)\n    print\\(f\"Final Score: {metadata.get\\('away_team'\\)} {metadata.get\\('final_away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {metadata.get\\('final_home_score'\\)}\"\\)\n    print\\(f\"Team we bet on: {team_abbrev}\"\\)\n    print\\(f\"Total frames: {len\\(frames\\)}\\\\n\"\\)\n    \n    # Determine if we bet on home or away\n    is_home = \\(team_abbrev == metadata.get\\('home_team'\\)\\)\n    \n    # Find the entry point \\(look for when market is around 92-94 cents\\)\n    # NOTE: Prices in the data are already in dollar format \\(0.92 = 92 cents\\)\n    entry_frame = None\n    entry_idx = None\n    \n    for idx, frame in enumerate\\(frames\\):\n        if is_home:\n            bid = frame.get\\('home_bid', 0.0\\)\n            ask = frame.get\\('home_ask', 1.0\\)\n        else:\n            bid = frame.get\\('away_bid', 0.0\\)\n            ask = frame.get\\('away_ask', 1.0\\)\n        \n        mid_price = \\(bid + ask\\) / 2.0\n        \n        # Look for entry around 90-96 cents\n        if 0.89 <= mid_price <= 0.96:\n            entry_frame = frame\n            entry_idx = idx\n            break\n    \n    if not entry_frame:\n        print\\(\"Could not find entry point in 89-96 cent range!\"\\)\n        # Try to find the highest price\n        max_price = 0\n        max_idx = 0\n        for idx, frame in enumerate\\(frames\\):\n            if is_home:\n                bid = frame.get\\('home_bid', 0.0\\)\n                ask = frame.get\\('home_ask', 1.0\\)\n            else:\n                bid = frame.get\\('away_bid', 0.0\\)\n                ask = frame.get\\('away_ask', 1.0\\)\n            mid = \\(bid + ask\\) / 2\n            if mid > max_price:\n                max_price = mid\n                max_idx = idx\n                entry_frame = frame\n                entry_idx = idx\n        print\\(f\"Using highest price found: ${max_price:.2f} at frame {max_idx}\\\\n\"\\)\n    \n    # Print entry context\n    print\\(f\"ENTRY POINT \\(frame #{entry_idx} of {len\\(frames\\)}\\):\"\\)\n    print\\(f\"  Period: {entry_frame.get\\('period'\\)}\"\\)\n    print\\(f\"  Time remaining: {entry_frame.get\\('time_remaining'\\)}\"\\)\n    print\\(f\"  Score: {metadata.get\\('away_team'\\)} {entry_frame.get\\('away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {entry_frame.get\\('home_score'\\)}\"\\)\n    \n    if is_home:\n        bid = entry_frame.get\\('home_bid', 0.0\\)\n        ask = entry_frame.get\\('home_ask', 1.0\\)\n    else:\n        bid = entry_frame.get\\('away_bid', 0.0\\)\n        ask = entry_frame.get\\('away_ask', 1.0\\)\n    \n    print\\(f\"  Market price: Bid ${bid:.2f}, Ask ${ask:.2f}, Mid ${\\(bid+ask\\)/2:.2f}\"\\)\n    \n    # Calculate score differential at entry\n    away_score = entry_frame.get\\('away_score', 0\\)\n    home_score = entry_frame.get\\('home_score', 0\\)\n    if is_home:\n        score_diff = home_score - away_score\n    else:\n        score_diff = away_score - home_score\n    \n    print\\(f\"  {team_abbrev} {'leading' if score_diff > 0 else 'trailing'} by: {abs\\(score_diff\\)} points\"\\)\n    print\\(f\"  Win probability \\(implied\\): {\\(bid+ask\\)/2*100:.1f}%\"\\)\n    \n    # Show key moments after entry\n    print\\(f\"\\\\nKEY MOMENTS AFTER ENTRY:\"\\)\n    print\\(f\"  {'Frame':<8} {'Period':<8} {'Time Left':<12} {'Away':<6} {'Home':<6} {team_abbrev + ' Lead':<12} {'Market :<10} {'Win %':<8}\"\\)\n    print\\(f\"  {'-'*80}\"\\)\n    \n    step = max\\(1, \\(len\\(frames\\) - entry_idx\\) // 20\\)\n    for i in range\\(entry_idx, len\\(frames\\), step\\):\n        frame = frames[i]\n        away_sc = frame.get\\('away_score', 0\\)\n        home_sc = frame.get\\('home_score', 0\\)\n        \n        if is_home:\n            lead = home_sc - away_sc\n            bid = frame.get\\('home_bid', 0.0\\)\n            ask = frame.get\\('home_ask', 1.0\\)\n        else:\n            lead = away_sc - home_sc\n            bid = frame.get\\('away_bid', 0.0\\)\n            ask = frame.get\\('away_ask', 1.0\\)\n        \n        mid = \\(bid + ask\\) / 2.0\n        \n        print\\(f\"  {i:<8} {frame.get\\('period', 'N/A'\\):<8} {frame.get\\('time_remaining', 'N/A'\\):<12} \"\n              f\"{away_sc:<6} {home_sc:<6} {'+' if lead > 0 else ''}{lead:<12} ${mid:<9.2f} {mid*100:<7.1f}%\"\\)\n    \n    # Final frame\n    print\\(f\"\\\\nFINAL RESULT:\"\\)\n    print\\(f\"  Score: {metadata.get\\('away_team'\\)} {metadata.get\\('final_away_score'\\)} - \"\n          f\"{metadata.get\\('home_team'\\)} {metadata.get\\('final_home_score'\\)}\"\\)\n    \n    away_final = metadata.get\\('final_away_score', 0\\)\n    home_final = metadata.get\\('final_home_score', 0\\)\n    \n    if is_home:\n        won = home_final > away_final\n        final_margin = home_final - away_final\n    else:\n        won = away_final > home_final\n        final_margin = away_final - home_final\n    \n    print\\(f\"  Result: {team_abbrev} {'WON' if won else 'LOST'}\"\\)\n    print\\(f\"  Final margin: {'+' if final_margin > 0 else ''}{final_margin} points\"\\)\n    \n    # Calculate the collapse\n    print\\(f\"\\\\nTHE COLLAPSE:\"\\)\n    print\\(f\"  Lead at entry: {'+' if score_diff > 0 else ''}{score_diff}\"\\)\n    print\\(f\"  Final margin: {'+' if final_margin > 0 else ''}{final_margin}\"\\)\n    print\\(f\"  Total swing: {score_diff - final_margin} points against us\"\\)\n    if is_home:\n        bid_entry = entry_frame.get\\('home_bid', 0.0\\)\n        ask_entry = entry_frame.get\\('home_ask', 1.0\\)\n    else:\n        bid_entry = entry_frame.get\\('away_bid', 0.0\\)\n        ask_entry = entry_frame.get\\('away_ask', 1.0\\)\n    print\\(f\"  Win probability at entry: {\\(bid_entry+ask_entry\\)/2*100:.1f}%\"\\)\n    print\\(f\"  Actual result: {'Win \\(1.0\\)' if won else 'Loss \\(0.0\\)'}\"\\)\n    print\\(f\"  Expected profit: ${\\(bid_entry+ask_entry\\)/2 * 5:.2f} on $5 bet\"\\)\n    print\\(f\"  Actual profit: ${\\(1.0 if won else 0.0\\) * 5 - 5:.2f}\"\\)\n\n# Analyze the two big losers\nprint\\(\"=\" * 100\\)\nprint\\(\"DEEP DIVE: BIG LOSING TRADES\"\\)\nprint\\(\"=\" * 100\\)\n\nprint\\(\"\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #1: Memphis Grizzlies @ Golden State Warriors \\(-$4.63\\)\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/MEM_vs_GSW_20260209_212836.json\", \"MEM\"\\)\n\nprint\\(\"\\\\n\\\\n\" + \"=\" * 100\\)\nprint\\(\"LOSS #2: Houston Rockets @ New York Knicks \\(-$4.72\\)\"\\)\nprint\\(\"=\" * 100\\)\nanalyze_game\\(\"data/recordings/HOU_vs_NYK_20260221_201054.json\", \"HOU\"\\)\n\nEOF)",
